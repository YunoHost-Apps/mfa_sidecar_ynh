#!/usr/bin/env bash
set -euo pipefail

if [[ "$1 $2" == "domain list" ]]; then
  cat <<'EOF'
{"domains":["wm3v.com","home.wm3v.com","auth.wm3v.com"]}
EOF
  exit 0
fi

if [[ "$1 $2" == "app list" ]]; then
  cat <<'EOF'
{"apps":[
  {"id":"homebox","label":"Homebox","domain":"home.wm3v.com","path":"/"},
  {"id":"nextcloud","label":"Nextcloud","domain":"wm3v.com","path":"/nextcloud"},
  {"id":"kanboard","label":"Kanboard","domain":"wm3v.com","path":"/kanboard"}
]}
EOF
  exit 0
fi

exit 1
