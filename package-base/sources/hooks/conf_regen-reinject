#!/bin/bash
[[ "$1" == "post" && "$2" == "nginx" ]] || exit 0
if [[ -x /opt/yunohost/mfa_sidecar/bin/inject_protected_include.py && -f /opt/yunohost/mfa_sidecar/deploy/generated-alpha/render-index.json ]]; then
  python3 /opt/yunohost/mfa_sidecar/bin/inject_protected_include.py reinject-all /opt/yunohost/mfa_sidecar/deploy/generated-alpha/render-index.json || true
fi
