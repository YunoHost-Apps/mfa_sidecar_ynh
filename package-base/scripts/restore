#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

_mfa_sidecar_resolve_paths

ynh_restore "/etc/nginx/conf.d/${domain}.d/${app}.conf"
ynh_restore "/etc/mfa-sidecar"
ynh_restore "$install_dir/config/domain-policy.yaml"
ynh_restore "$install_dir/README.alpha"

_mfa_sidecar_write_env_file
chown -R root:root /etc/mfa-sidecar "$install_dir"
chmod 700 /etc/mfa-sidecar/secrets || true
chmod 600 /etc/mfa-sidecar/secrets/* /etc/mfa-sidecar/mfa-sidecar.env || true

_mfa_sidecar_remove_primary_domain_include
_mfa_sidecar_inject_primary_domain_include

ynh_script_progression "Reloading NGINX web server..."
ynh_systemctl --service=nginx --action=reload

ynh_script_progression "Reloading sidecar services if present..."
ynh_systemctl --service=mfa-sidecar-authelia --action=restart || true
_mfa_sidecar_assert_service_active mfa-sidecar-authelia

ynh_systemctl --service=mfa-sidecar-admin --action=restart || true
_mfa_sidecar_assert_service_active mfa-sidecar-admin

if ! _mfa_sidecar_wait_for_local_http \
    "http://127.0.0.1:9087/admin" 20 1 \
    "X-MFA-Sidecar-Admin-Secret" "$(grep '^MFA_SIDECAR_ADMIN_GATE_SECRET=' /etc/mfa-sidecar/mfa-sidecar.env | cut -d= -f2-)"; then
    _mfa_sidecar_dump_admin_diagnostics
    ynh_die "Admin UI did not become reachable on 127.0.0.1:9087/admin after restore"
fi

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Restoration completed for $app"
