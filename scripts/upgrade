#!/bin/bash

APP_SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$APP_SCRIPT_DIR/_common.sh"
source /usr/share/yunohost/helpers

_mfa_sidecar_resolve_paths
_mfa_sidecar_validate_inputs

#=================================================
# ENSURE CONFIG MATERIAL EXISTS
#=================================================
ynh_script_progression "Refreshing MFA Sidecar runtime..."

if [[ ! -f "/etc/nginx/conf.d/${domain}.conf" ]]; then
    ynh_script_progression "Portal domain nginx parent config missing; forcing regen-conf for nginx..."
    yunohost tools regen-conf nginx --force 2>/dev/null || true
fi

_mfa_sidecar_install_layout
_mfa_sidecar_install_packaged_files

find "$install_dir" -type d -name '__pycache__' -exec ynh_secure_remove --file={} \; 2>/dev/null || true

_mfa_sidecar_install_authelia_binary
_mfa_sidecar_write_secret_if_missing "$(_mfa_sidecar_secret_file session_secret)"
_mfa_sidecar_write_secret_if_missing "$(_mfa_sidecar_secret_file storage_encryption_key)"
_mfa_sidecar_write_secret_if_missing "$(_mfa_sidecar_secret_file identity_validation_reset_secret)"

_mfa_sidecar_write_env_file
ynh_app_setting_set --key=install_dir --value="$install_dir"
ynh_app_setting_set --key=data_dir --value="$data_dir"
ynh_app_setting_set_default --key=portal_subdomain --value="${portal_subdomain:-auth}"
ynh_app_setting_set_default --key=default_policy --value="${default_policy:-open}"
ynh_app_setting_set_default --key=session_duration --value="${session_duration:-24h}"
ynh_app_setting_set_default --key=upstream_scheme --value="${upstream_scheme:-https}"
ynh_app_setting_set_default --key=upstream_host --value="${upstream_host:-127.0.0.1}"
ynh_app_setting_set_default --key=upstream_port --value="${upstream_port:-443}"

if [[ ! -f "$install_dir/config/domain-policy.yaml" ]]; then
    _mfa_sidecar_write_policy_seed
fi

chown -R "$app:$app" "$install_dir" "$data_dir"
chown -R "$app:$app" /etc/mfa-sidecar/authelia /etc/mfa-sidecar/nginx /etc/mfa-sidecar/secrets
chown root:"$app" /etc/mfa-sidecar/mfa-sidecar.env
chmod 750 "$install_dir" "$install_dir/bin" "$install_dir/config" "$install_dir/run"
chmod 700 /etc/mfa-sidecar/secrets
chmod 750 /etc/mfa-sidecar /etc/mfa-sidecar/authelia /etc/mfa-sidecar/nginx /etc/mfa-sidecar/nginx/protected
chmod 640 /etc/mfa-sidecar/secrets/* /etc/mfa-sidecar/mfa-sidecar.env

_mfa_sidecar_sync_runtime_assets
_mfa_sidecar_sync_protected_domain_includes
_mfa_sidecar_install_reinject_hooks
_mfa_sidecar_write_sudoers
chown "$app:$app" /etc/mfa-sidecar/authelia/configuration.yml /etc/mfa-sidecar/authelia/users.yml
chmod 640 /etc/mfa-sidecar/authelia/configuration.yml /etc/mfa-sidecar/authelia/users.yml
_mfa_sidecar_write_runtime_notes

#=================================================
# CONFIGURE NGINX
#=================================================
ynh_script_progression "Refreshing NGINX entrypoint for MFA sidecar..."

if [[ ! -f "/etc/nginx/conf.d/${domain}.conf" ]]; then
    ynh_script_progression "Portal domain nginx parent config missing before NGINX refresh; forcing regen-conf for nginx..."
    yunohost tools regen-conf nginx --force 2>/dev/null || true
fi

mkdir -p "/etc/nginx/conf.d/${domain}.d"
cp /etc/mfa-sidecar/nginx/portal.conf "$APP_SCRIPT_DIR/../conf/nginx.conf"
ynh_config_add_nginx
_mfa_sidecar_inject_primary_domain_include

ynh_script_progression "Reloading sidecar services if present..."
systemctl daemon-reload || true
ynh_systemctl --service=mfa-sidecar-authelia --action=restart || true
_mfa_sidecar_assert_service_active mfa-sidecar-authelia

ynh_systemctl --service=mfa-sidecar-admin --action=restart || true
_mfa_sidecar_assert_service_active mfa-sidecar-admin

if ! _mfa_sidecar_wait_for_local_http \
    "http://127.0.0.1:9087/admin" 20 1 \
    "" "" \
    200; then
    _mfa_sidecar_dump_admin_diagnostics
    ynh_die "Admin UI did not become reachable on 127.0.0.1:9087/admin after upgrade"
fi

ynh_script_progression "Upgrade of $app completed"
