#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

_mfa_sidecar_resolve_paths

#=================================================
# REMOVE MANAGED INCLUDE + NGINX CONFIGURATION
#=================================================
_mfa_sidecar_remove_primary_domain_include
_mfa_sidecar_remove_protected_domain_includes
_mfa_sidecar_remove_reinject_hooks
_mfa_sidecar_remove_sudoers
ynh_systemctl --service=nginx --action=reload || true
ynh_config_remove_nginx

portal_nginx_conf="/etc/nginx/conf.d/${domain}.conf"
portal_nginx_dir="/etc/nginx/conf.d/${domain}.d"
if [[ -f "$portal_nginx_conf" ]]; then
    rm -f "$portal_nginx_conf"
fi
if [[ -d "$portal_nginx_dir" ]] && [[ -z "$(find "$portal_nginx_dir" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]]; then
    rmdir "$portal_nginx_dir" 2>/dev/null || true
fi

#=================================================
# DISABLE SERVICE (ALPHA DRAFT)
#=================================================
ynh_systemctl --service=mfa-sidecar-authelia --action=stop || true
ynh_systemctl --service=mfa-sidecar-authelia --action=disable || true
ynh_systemctl --service=mfa-sidecar-admin --action=stop || true
ynh_systemctl --service=mfa-sidecar-admin --action=disable || true
rm -f /etc/systemd/system/mfa-sidecar-authelia.service
rm -f /etc/systemd/system/mfa-sidecar-admin.service

#=================================================
# REMOVE RUNTIME ARTIFACTS
#=================================================
rm -rf /etc/mfa-sidecar
rm -rf /var/lib/mfa_sidecar
rm -rf "$install_dir"
systemctl daemon-reload || true

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Removal of $app completed"
