#!/bin/bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_common.sh"
source /usr/share/yunohost/helpers

_mfa_sidecar_resolve_paths

ynh_restore "/etc/nginx/conf.d/${domain}.d/${app}.conf"
ynh_restore "/etc/mfa-sidecar"
ynh_restore "$install_dir/config/domain-policy.yaml"
ynh_restore "$install_dir/README.package"

_mfa_sidecar_install_layout
_mfa_sidecar_install_packaged_files

_mfa_sidecar_write_env_file
ynh_app_setting_set --key=install_dir --value="$install_dir"
ynh_app_setting_set --key=data_dir --value="$data_dir"
chown -R "$app:$app" "$install_dir" "$data_dir"
chown -R "$app:$app" /etc/mfa-sidecar/authelia /etc/mfa-sidecar/nginx /etc/mfa-sidecar/secrets || true
chown root:"$app" /etc/mfa-sidecar/mfa-sidecar.env || true
chmod 750 "$install_dir" "$install_dir/bin" "$install_dir/config" "$install_dir/run" || true
chmod 700 /etc/mfa-sidecar/secrets || true
chmod 750 /etc/mfa-sidecar /etc/mfa-sidecar/authelia /etc/mfa-sidecar/nginx /etc/mfa-sidecar/nginx/protected || true
chmod 640 /etc/mfa-sidecar/secrets/* /etc/mfa-sidecar/mfa-sidecar.env || true
chown "$app:$app" /etc/mfa-sidecar/authelia/configuration.yml /etc/mfa-sidecar/authelia/users.yml 2>/dev/null || true
chmod 640 /etc/mfa-sidecar/authelia/configuration.yml /etc/mfa-sidecar/authelia/users.yml 2>/dev/null || true

mkdir -p "/etc/nginx/conf.d/${domain}.d"
_mfa_sidecar_remove_primary_domain_include
_mfa_sidecar_inject_primary_domain_include
_mfa_sidecar_sync_protected_domain_includes

ynh_script_progression "Reloading NGINX web server..."
ynh_systemctl --service=nginx --action=reload

ynh_script_progression "Reloading sidecar services if present..."
systemctl daemon-reload || true
ynh_systemctl --service=mfa-sidecar-authelia --action=restart || true
_mfa_sidecar_assert_service_active mfa-sidecar-authelia

ynh_systemctl --service=mfa-sidecar-admin --action=restart || true
_mfa_sidecar_assert_service_active mfa-sidecar-admin

if ! _mfa_sidecar_wait_for_local_http \
    "http://127.0.0.1:9087/admin" 20 1 \
    "" "" \
    200; then
    _mfa_sidecar_dump_admin_diagnostics
    ynh_die "Admin UI did not become reachable on 127.0.0.1:9087/admin after restore"
fi

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Restoration completed for $app"
