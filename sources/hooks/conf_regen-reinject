#!/bin/bash
[[ "$1" == "post" && "$2" == "nginx" ]] || exit 0
INSTALL_DIR="${MFA_SIDECAR_INSTALL_DIR:-/opt/yunohost/mfa_sidecar}"
ENV_FILE="/etc/mfa-sidecar/mfa-sidecar.env"
[[ -f "$ENV_FILE" ]] && . "$ENV_FILE"
INJECTOR="$INSTALL_DIR/bin/inject_protected_include.py"
RENDER_INDEX="$INSTALL_DIR/deploy/generated-runtime/render-index.json"
if [[ -x "$INJECTOR" && -f "$RENDER_INDEX" ]]; then
  python3 "$INJECTOR" reinject-all "$RENDER_INDEX" || true
fi
nginx -t >/dev/null 2>&1 && systemctl reload nginx 2>/dev/null || true
