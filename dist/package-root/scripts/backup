#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

_mfa_sidecar_resolve_paths

#=================================================
# BACKUP THE NGINX CONFIGURATION + ALPHA RUNTIME STATE
#=================================================

ynh_backup "/etc/nginx/conf.d/${domain}.d/${app}.conf"
ynh_backup "/etc/mfa-sidecar"  # includes generated admin gate secret/env/runtime assets
ynh_backup "$install_dir/config/domain-policy.yaml"
ynh_backup "$install_dir/README.alpha"

#=================================================
# END OF SCRIPT
#=================================================

ynh_print_info "Backup script completed for $app. (YunoHost will then actually copy those files to the archive)."
