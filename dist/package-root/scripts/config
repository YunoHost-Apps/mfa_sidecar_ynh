#!/bin/bash
source /usr/share/yunohost/helpers

ynh_abort_if_errors

APP_INSTALL_DIR="${install_dir:-$(ynh_app_setting_get --key=install_dir)}"
APP_DATA_DIR="${data_dir:-$(ynh_app_setting_get --key=data_dir)}"
POLICY_FILE="$APP_INSTALL_DIR/config/domain-policy.yaml"

get__upstream_scheme() {
    ynh_app_setting_get --key=upstream_scheme
}

get__upstream_host() {
    ynh_app_setting_get --key=upstream_host
}

get__upstream_port() {
    ynh_app_setting_get --key=upstream_port
}

set__default_policy() {
    ynh_app_setting_set --key=default_policy --value="$default_policy"
}

set__remember_me() {
    case "$remember_me" in
        8h|24h|168h|336h|720h) ;;
        *) echo "Unsupported remembered session duration: $remember_me"; return 1 ;;
    esac
    ynh_app_setting_set --key=session_duration --value="$remember_me"
}

validate__upstream_scheme() {
    [[ "$upstream_scheme" =~ ^(http|https)$ ]] || echo "Scheme must be http or https"
}

validate__upstream_host() {
    [[ -n "$upstream_host" ]] || echo "Host cannot be empty"
}

validate__upstream_port() {
    [[ "$upstream_port" =~ ^[0-9]+$ ]] && (( upstream_port >= 1 && upstream_port <= 65535 )) || echo "Port must be a valid TCP port"
}

run__save_upstream_defaults() {
    ynh_app_setting_set --key=upstream_scheme --value="$upstream_scheme"
    ynh_app_setting_set --key=upstream_host --value="$upstream_host"
    ynh_app_setting_set --key=upstream_port --value="$upstream_port"
    ynh_print_info "Saved default upstream seed to YunoHost app settings. Existing managed entries were not rewritten."
}

run__reload_runtime() {
    local install_dir data_dir
    install_dir="$APP_INSTALL_DIR"
    data_dir="$APP_DATA_DIR"

    python3 "$install_dir/bin/render_alpha_config.py" \
        "$POLICY_FILE" \
        "$install_dir/deploy/generated-alpha"

    python3 "$install_dir/bin/stage_alpha_runtime.py" \
        "$install_dir/deploy/generated-alpha" /

    cp /etc/mfa-sidecar/nginx/portal.conf ../conf/nginx.conf
    ynh_config_add_nginx
    ynh_systemctl --service=nginx --action=reload
    ynh_systemctl --service=mfa-sidecar-authelia --action=restart
    ynh_systemctl --service=mfa-sidecar-admin --action=restart
    ynh_print_info "Regenerated runtime assets and restarted MFA Sidecar services."
}

ynh_app_config_run "$1"
