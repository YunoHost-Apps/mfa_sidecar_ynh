# Copy to /etc/mfa-sidecar/mfa-sidecar.env and replace placeholders.
AUTHELIA_SESSION_SECRET=replace-with-long-random-secret
AUTHELIA_STORAGE_ENCRYPTION_KEY=replace-with-long-random-secret
AUTHELIA_IDENTITY_VALIDATION_RESET_SECRET=replace-with-long-random-secret
AUTHELIA_LDAP_PASSWORD=replace-with-ldap-bind-password
